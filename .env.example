# Google OAuth 2.0 Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=

# YouTube Data API v3 Key (public fallback for unauthenticated searches)
VITE_YOUTUBE_API_KEY=

# YouTube Channel ID — restricts searches to this channel only (optional)
# Find yours at: https://www.youtube.com/channel/YOUR_CHANNEL_ID
VITE_YOUTUBE_CHANNEL_ID=
